name: Build Unix Executable

on:
  workflow_dispatch:
    inputs:
      release_type:
        description: 'Release type (debug/release)'
        required: true
        default: 'release'

jobs:
  build:
    runs-on: ubuntu-latest
    
    steps:
      - name: Checkout code
        uses: actions/checkout@v4
      
      - name: Setup environment
        run: |
          # Add your dependency installation here
          # Example: sudo apt-get install -y build-essential
          
      - name: Build executable
        run: |
          # Replace with your actual build command
          # Examples:
          # make build
          # cargo build --release
          # ./build.sh
          chmod +x ./build.sh
          ./build.sh
      
      - name: Upload artifact
        uses: actions/upload-artifact@v4
        with:
          name: unix-executable
          path: ./dist/  # Adjust path to where your executable is built
      
      - name: Create Release
        uses: softprops/action-gh-release@v1
        if: startsWith(github.ref, 'refs/tags/')
        with:
          files: ./dist/**/*
